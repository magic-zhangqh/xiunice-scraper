# ===========================================
# Notification settings
# ===========================================
# 通知方式: gotify | email  (默认 gotify)
NOTIFY_METHOD=gotify

# --- Gotify (自建推送) ---
GOTIFY_URL=http://10.10.1.180:11080
GOTIFY_TOKEN=your_token_here
GOTIFY_PRIORITY=5

# --- Email (SMTP) ---
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=123456@qq.com
# QQ邮箱使用授权码, 非登录密码
SMTP_PASSWORD=your_auth_code_here
EMAIL_FROM=123456@qq.com
# 接收通知的邮箱, 默认同 EMAIL_FROM
EMAIL_TO=
